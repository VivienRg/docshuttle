# ── Cloudflare ────────────────────────────────────────────────
# Worker name (must be unique within your Cloudflare account)
WORKER_NAME=docshuttle

# KV namespace ID (from Cloudflare dashboard → Workers & Pages → KV)
KV_NAMESPACE_ID=your-kv-namespace-id

# ── Portal branding ───────────────────────────────────────────
COMPANY_NAME=Your Company Name
PORTAL_TITLE=Your Portal Title

# ── Google OAuth secrets ──────────────────────────────────────
# See SETUP.md for instructions on obtaining these values.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret
GOOGLE_REFRESH_TOKEN=1//your-refresh-token

# ── Google Drive ──────────────────────────────────────────────
# Comma-separated list of root folder IDs to index
FOLDER_IDS=folder-id-1,folder-id-2
